engine-strict = true
# 4 days (in minutes)
minimum-release-age = 5760

# Tailwind v4 packages — pinned via package.json, allow installing fresh releases.
# All @tailwindcss/* packages release together, so exclude the whole family.
minimum-release-age-exclude[]=tailwindcss
minimum-release-age-exclude[]=@tailwindcss/vite
minimum-release-age-exclude[]=@tailwindcss/node
minimum-release-age-exclude[]=@tailwindcss/oxide
minimum-release-age-exclude[]=@tailwindcss/oxide-android-arm64
minimum-release-age-exclude[]=@tailwindcss/oxide-darwin-arm64
minimum-release-age-exclude[]=@tailwindcss/oxide-darwin-x64
minimum-release-age-exclude[]=@tailwindcss/oxide-freebsd-x64
minimum-release-age-exclude[]=@tailwindcss/oxide-linux-arm-gnueabihf
minimum-release-age-exclude[]=@tailwindcss/oxide-linux-arm64-gnu
minimum-release-age-exclude[]=@tailwindcss/oxide-linux-arm64-musl
minimum-release-age-exclude[]=@tailwindcss/oxide-linux-x64-gnu
minimum-release-age-exclude[]=@tailwindcss/oxide-linux-x64-musl
minimum-release-age-exclude[]=@tailwindcss/oxide-wasm32-wasi
minimum-release-age-exclude[]=@tailwindcss/oxide-win32-arm64-msvc
minimum-release-age-exclude[]=@tailwindcss/oxide-win32-x64-msvc
