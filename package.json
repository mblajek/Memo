{
  "name": "fdds-memo",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm install && vite",
    "build": "pnpm install --prod && vite build --sourcemap",
    "build-debug": "pnpm install --prod && vite build --no-minify --sourcemap=inline",
    "clean": "rm -rf public/build",
    "format": "pnpm install && prettier resources/js --write",
    "typecheck": "pnpm install && tsc --noEmit",
    "typecheck-watch": "pnpm install && tsc --noEmit --watch",
    "test": "pnpm install && vitest run",
    "test-watch": "pnpm install && vitest watch",
    "coverage": "pnpm install && vitest run --coverage",
    "lint": "pnpm install && eslint resources/js"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/luxon": "^3.7.1",
    "@types/wicg-file-system-access": "^2023.10.7",
    "eslint": "^9.39.4",
    "eslint-config-love": "^153.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@felte/core": "^1.4.4",
    "@felte/reporter-solid": "^1.2.11",
    "@felte/solid": "^1.2.14",
    "@felte/validator-zod": "^1.0.18",
    "@floating-ui/core": "^1.7.5",
    "@floating-ui/dom": "^1.7.6",
    "@mbarzda/solid-i18next": "^1.4.1",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "@tanstack/solid-query": "^5.99.2",
    "@tanstack/solid-table": "^8.21.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/table-core": "^8.21.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "axios": "^1.15.2",
    "bowser": "^2.14.1",
    "classnames": "^2.5.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "headless-qr": "^1.0.3",
    "html-parse-string": "^0.0.9",
    "i18next": "^26.0.6",
    "i18next-http-backend": "^3.0.5",
    "i18next-intervalplural-postprocessor": "^3.0.0",
    "js-base64": "^3.7.8",
    "laravel-vite-plugin": "^2.1.0",
    "libphonenumber-js": "^1.12.41",
    "luxon": "^3.7.2",
    "rehype-autolink-headings": "^7.1.0",
    "remark-custom-heading-id": "^2.0.0",
    "remark-gfm": "^4.0.1",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.12",
    "solid-markdown": "^2.1.1",
    "solid-toast": "^0.5.0",
    "tailwindcss": "^4.3.0",
    "tippy.js": "^6.3.7",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-solid-svg": "^0.8.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10",
    "npm": "use-pnpm-instead"
  }
}
